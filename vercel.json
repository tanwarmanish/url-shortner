{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "cd apps/web && npx vite build",
  "outputDirectory": "dist/apps/web",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
